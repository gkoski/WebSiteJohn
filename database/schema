CREATE DATABASE IF NOT EXISTS mrjohn_db;
USE mrjohn_db;

CREATE TABLE tb_categoria (
    categoria_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(255) NOT NULL
);

CREATE TABLE tb_produto (
    produto_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(255) NOT NULL,
    descricao VARCHAR(255),
    preco DECIMAL(19,2) NOT NULL,
    foto VARCHAR(255),
    categoria_id BIGINT,
    CONSTRAINT fk_produto_categoria FOREIGN KEY (categoria_id) REFERENCES tb_categoria(categoria_id)
);

CREATE TABLE tb_usuario (
    usuario_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    cpf VARCHAR(11) NOT NULL UNIQUE,
    email VARCHAR(255) NOT NULL UNIQUE,
    login VARCHAR(255) NOT NULL UNIQUE,
    senha VARCHAR(255) NOT NULL
);

CREATE TABLE tb_pedido (
    pedido_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    data_pedido DATETIME NOT NULL,
    valor_total DECIMAL(10,2),
    status VARCHAR(255),
    usuario_id BIGINT,
    CONSTRAINT fk_usuario_pedido FOREIGN KEY (usuario_id) REFERENCES tb_usuario(usuario_id)
);

CREATE TABLE tb_pedido_itens (
    item_pedido_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    quantidade INT NOT NULL,
    preco_unitario DECIMAL(10,2),
    pedido_id BIGINT,
    produto_id BIGINT,
    CONSTRAINT fk_pedido_itens_id FOREIGN KEY (pedido_id) REFERENCES tb_pedido(pedido_id),
    CONSTRAINT fk_produto_itens_id FOREIGN KEY (produto_id) REFERENCES tb_produto(produto_id)
);

CREATE INDEX idx_pedidos_usuario_id ON tb_pedido (usuario_id);
